{
  "name": "reactor-logic-foam-run",
  "version": "0.1.0",
  "private": true,
  "description": "Expandable React, TypeScript, and Three.js educational maze prototype.",
  "scripts": {
    "start": "webpack serve --mode development --host 0.0.0.0",
    "build": "webpack --mode production",
    "typecheck": "tsc --noEmit",
    "pages:preview": "npm run build && wrangler pages dev dist",
    "pages:deploy": "npm run build && wrangler pages deploy dist --project-name reactor-logic-foam-run",
    "cf:whoami": "wrangler whoami"
  },
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.17.10",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.170.0",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.3",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.6.3",
    "webpack": "^5.96.1",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.1.0",
    "wrangler": "^4.90.0"
  }
}
